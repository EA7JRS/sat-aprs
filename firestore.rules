rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is the master developer / creator
    function isCreator() {
      return request.auth != null && 
        (request.auth.token.email == 'manuelcancasanchez@gmail.com' || 
         request.auth.token.email.toLowerCase() == 'manuelcancasanchez@gmail.com');
    }

    // Global safety net: default deny except for the master creator
    match /{document=**} {
      allow read, write: if isCreator();
    }

    // User profiles and settings
    match /users/{userId} {
      allow read, write: if isCreator() || (request.auth != null && request.auth.uid == userId);
    }

    // User stations subcollection
    match /users/{userId}/stations/{stationId} {
      allow read, write: if isCreator() || (request.auth != null && request.auth.uid == userId);
    }

    // Global system configuration and version controls
    match /system/{document} {
      allow read: if request.auth != null;
      allow write: if isCreator() || (request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isRemer == true);
    }
  }
}
